# Supabase — required for all monitoring
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SRK=<service-role-key>

# Telegram alerts — required for downtime notifications
TELEGRAM_BOT_TOKEN=<bot-token-from-botfather>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# DRY_RUN flags — set true during setup, false in production
CLOUDFLARE_DRY_RUN=true
X_DRY_RUN=true

# Site URL — used in daily digest
SITE_URL=https://outageiq.io
